rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /huishoudboekjes/{bookId} {
      allow read: if request.auth != null &&
                  (resource.data.ownerId == request.auth.uid ||
                   request.auth.uid in resource.data.members);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }
    match /householdbooks/{bookId} {
      allow read: if request.auth != null &&
                  (resource.data.ownerId == request.auth.uid ||
                   request.auth.uid in resource.data.members);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    function isBookMember(bookId) {
      let bookData = get(/databases/$(database)/documents/householdbooks/$(bookId)).data;
      return request.auth.uid == bookData.ownerId || request.auth.uid in bookData.members;
    }

    match /categories/{categoryId} {
      allow read: if request.auth != null && isBookMember(resource.data.bookId);
      allow create: if request.auth != null
                    && isBookMember(request.resource.data.bookId)
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
                   && isBookMember(resource.data.bookId)
                   && request.resource.data.bookId == resource.data.bookId;
      allow delete: if request.auth != null && isBookMember(resource.data.bookId);
    }

    match /transactions/{transactionId} {
      allow read: if request.auth != null && isBookMember(resource.data.bookId);
      allow create: if request.auth != null
                    && isBookMember(request.resource.data.bookId)
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
                    && isBookMember(resource.data.bookId)
                    && request.resource.data.bookId == resource.data.bookId;
      allow delete: if request.auth != null && isBookMember(resource.data.bookId);
    }
  }
}
